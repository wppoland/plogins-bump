#. Plugin Name of the plugin
#: plogins-bump.php
msgid "Plogins Bump - Checkout Order Bump for WooCommerce"
msgstr "Plogins Bump – order bump na checkoucie dla WooCommerce"

#. Description of the plugin
#: plogins-bump.php
msgid "Show a one-click order-bump offer on the checkout so shoppers can add a complementary product before they pay."
msgstr "Pokazuje na checkoucie ofertę order bump jednym kliknięciem, aby klient mógł dodać uzupełniający produkt przed zapłatą."

#: plogins-bump.php
msgid "Plogins Bump requires WooCommerce to be active."
msgstr "Plogins Bump wymaga aktywnego WooCommerce."

#: src/Admin/Settings.php
msgid "Bump – Order Bump"
msgstr "Bump – order bump"

#: src/Admin/Settings.php
msgid "Settings"
msgstr "Ustawienia"

#: src/Admin/Settings.php
msgid "Show a one-click order-bump offer above the payment methods on the checkout. Ticking it adds the product to the order and recalculates the total before payment."
msgstr "Pokaż ofertę order bump jednym kliknięciem nad metodami płatności na checkoucie. Zaznaczenie dodaje produkt do zamówienia i przelicza sumę przed płatnością."

#: src/Admin/Settings.php
msgid "Enable order bump"
msgstr "Włącz order bump"

#: src/Admin/Settings.php
msgid "Show the order-bump offer on the checkout."
msgstr "Pokaż ofertę order bump na checkoucie."

#: src/Admin/Settings.php
msgid "Bump product"
msgstr "Produkt bumpa"

#: src/Admin/Settings.php
msgid "— Select a product —"
msgstr "— Wybierz produkt —"

#: src/Admin/Settings.php
msgid "A simple, purchasable product offered as the bump. Pick something cheap and complementary."
msgstr "Prosty, możliwy do kupienia produkt oferowany jako bump. Wybierz coś taniego i uzupełniającego."

#: src/Admin/Settings.php
msgid "Heading"
msgstr "Nagłówek"

#: src/Admin/Settings.php src/Service/BumpService.php
msgid "One-time offer"
msgstr "Oferta jednorazowa"

#: src/Admin/Settings.php
msgid "Checkbox label"
msgstr "Etykieta pola wyboru"

#: src/Admin/Settings.php src/Service/BumpService.php
msgid "Yes, add this to my order!"
msgstr "Tak, dodaj do zamówienia!"

#: src/Admin/Settings.php
msgid "Description"
msgstr "Opis"

#: src/Admin/Settings.php
msgid "Override price"
msgstr "Nadpisz cenę"

#: src/Admin/Settings.php
msgid "Optional special price for the bump line only (e.g. 19.00). Leave empty to use the product's normal price."
msgstr "Opcjonalna specjalna cena tylko dla linii bumpa (np. 19.00). Zostaw puste, aby użyć normalnej ceny produktu."

#: src/Admin/Settings.php
msgid "Accent colour"
msgstr "Kolor akcentu"
